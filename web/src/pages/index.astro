---
import Layout from '../layouts/Layout.astro';
import StrategyCallForm from '../components/StrategyCallForm';
import CodeExperience from '../components/world/code/CodeExperience';
---

<Layout
	title="Inkblot Studio | AI Operating Systems"
	description="Fully immersive 3D AI operating system experience."
>
	<main>
		<CodeExperience client:only="react" />

		<section id="strategy-call" class="site-container py-20">
			<div class="section-card rounded-3xl p-8 md:p-12">
				<h2 class="text-3xl font-semibold md:text-5xl">Enter the build queue for a tailored growth roadmap.</h2>
				<p class="muted mt-4 max-w-2xl text-lg">
					You have seen the immersive model. Now submit your operational context and we will return a
					high-signal implementation path with manual review from our side.
				</p>
				<StrategyCallForm client:load />
			</div>
		</section>
	</main>
</Layout>
