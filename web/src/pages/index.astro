---
import Layout from '../layouts/Layout.astro';
import HeroScene from '../components/HeroScene';
import NarrativeFlowScene from '../components/NarrativeFlowScene';
import StrategyCallForm from '../components/StrategyCallForm';
---

<Layout
	title="Inkblot Studio | AI Operating Systems"
	description="The red pill for businesses stuck in outdated software."
>
	<main>
		<section class="site-container grid min-h-[84vh] items-center gap-8 py-16 md:grid-cols-[1fr_1.1fr] md:py-20">
			<div class="space-y-6">
				<p class="inline-block rounded-full border border-inkblot-cyan/45 px-4 py-1 text-sm text-inkblot-cyan-soft">
					European coverage | Limited premium founder slots
				</p>
				<h1 class="text-4xl leading-tight font-semibold md:text-6xl">
					The red pill for businesses stuck in outdated software.
				</h1>
				<p class="muted max-w-xl text-lg">
					We design privacy-first AI operating systems for European companies - simple for owners,
					powerful under the hood, and built to move operations faster.
				</p>
				<div class="flex flex-wrap gap-3">
					<a
						href="#strategy-call"
						class="rounded-full bg-inkblot-cyan px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-inkblot-cyan-soft"
					>
						Get My Growth Roadmap
					</a>
					<a
						href="#method"
						class="rounded-full border border-white/25 px-6 py-3 text-sm font-medium text-white transition hover:border-inkblot-cyan"
					>
						Explore Our Method
					</a>
				</div>
			</div>
			<div class="section-card overflow-hidden rounded-3xl p-3">
				<HeroScene client:only="react" />
			</div>
		</section>

		<section class="site-container py-10 md:py-16">
			<h2 class="text-3xl font-semibold md:text-4xl">
				Most companies do not have a people problem. They have a workflow problem.
			</h2>
			<p class="muted mt-4 max-w-3xl text-lg">
				Teams lose time across disconnected tools, manual handoffs, and dashboard overload. Inkblot
				replaces operational friction with AI-assisted execution your team can actually use.
			</p>
		</section>

		<section class="site-container py-6 md:py-10">
			<div class="grid gap-4 md:grid-cols-3">
				<article class="section-card rounded-2xl p-6">
					<h3 class="text-xl font-semibold">Outdated workflows and bottlenecks</h3>
					<p class="muted mt-3">We map friction points and redesign execution for speed.</p>
				</article>
				<article class="section-card rounded-2xl p-6">
					<h3 class="text-xl font-semibold">Too many tools, no clear control</h3>
					<p class="muted mt-3">We unify process logic into one intelligent operating layer.</p>
				</article>
				<article class="section-card rounded-2xl p-6">
					<h3 class="text-xl font-semibold">No time for risky transformations</h3>
					<p class="muted mt-3">We launch in practical phases: Audit -> Build -> Optimize.</p>
				</article>
			</div>
		</section>

		<section id="method" class="site-container py-14 md:py-18">
			<h2 class="text-3xl font-semibold md:text-4xl">Simple for owners. Powerful under the hood.</h2>
			<div class="mt-6 grid gap-4 md:grid-cols-3">
				<article class="section-card rounded-2xl p-6">
					<p class="text-sm text-inkblot-cyan-soft">Step 1</p>
					<h3 class="mt-2 text-xl font-semibold">Audit</h3>
					<p class="muted mt-3">Pinpoint where execution speed is leaking across your workflows.</p>
				</article>
				<article class="section-card rounded-2xl p-6">
					<p class="text-sm text-inkblot-cyan-soft">Step 2</p>
					<h3 class="mt-2 text-xl font-semibold">Build</h3>
					<p class="muted mt-3">Deploy an AI operating layer tailored to your team and process.</p>
				</article>
				<article class="section-card rounded-2xl p-6">
					<p class="text-sm text-inkblot-cyan-soft">Step 3</p>
					<h3 class="mt-2 text-xl font-semibold">Optimize</h3>
					<p class="muted mt-3">Continuously tune orchestration and outcomes with a 3-month retainer.</p>
				</article>
			</div>
		</section>

		<section class="site-container py-8 md:py-12">
			<div class="grid items-center gap-6 md:grid-cols-[1fr_1.1fr]">
				<div>
					<h2 class="text-3xl font-semibold md:text-4xl">See how your workflow evolves under one intelligent layer.</h2>
					<p class="muted mt-4 text-lg">
						This narrative view models how disconnected operational steps become one guided flow. It
						uses adaptive rendering to keep performance and accessibility balanced across devices.
					</p>
				</div>
				<div class="section-card overflow-hidden rounded-3xl p-3">
					<NarrativeFlowScene client:load />
				</div>
			</div>
		</section>

		<section id="strategy-call" class="site-container py-20">
			<div class="section-card rounded-3xl p-8 md:p-12">
				<h2 class="text-3xl font-semibold md:text-5xl">Your next system should feel simple.</h2>
				<p class="muted mt-4 max-w-2xl text-lg">
					If your operations are growing but your software is slowing you down, we will map a better
					path and show exactly how to execute it.
				</p>
				<StrategyCallForm client:load />
			</div>
		</section>
	</main>
</Layout>
